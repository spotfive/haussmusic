{
  "name": "Playlist",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Nome da playlist"
    },
    "description": {
      "type": "string"
    },
    "cover_url": {
      "type": "string"
    },
    "song_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "is_public": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "name"
  ]
}