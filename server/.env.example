# Copy to server/.env and fill in before running the server.

# Any long random string — used to sign login sessions (JWT).
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Comma-separated emails that are always granted the admin role
# (the very first person to ever register also becomes admin automatically).
ADMIN_EMAILS=steffanbaum123@gmail.com

# Same Google OAuth Client ID used by the frontend (VITE_GOOGLE_CLIENT_ID),
# needed here so the server can verify Google sign-in tokens. Leave blank
# to disable "Sign in with Google".
GOOGLE_CLIENT_ID=

# Which frontend origin(s) are allowed to call this API. Use "*" while
# testing locally; set it to your real site URL once deployed.
CORS_ORIGIN=*

# Base URL this server is reachable at, used to build public file URLs
# (e.g. https://api.yoursite.com). Defaults to the request's own host if
# unset.
PUBLIC_URL=

PORT=3001

# Where the SQLite file and uploaded files live. Point this at a mounted
# volume in production so data survives restarts/redeploys.
DATA_DIR=./data
UPLOADS_DIR=./uploads
